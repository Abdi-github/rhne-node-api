{
  "info": {
    "name": "RHNe API — Réseau Hospitalier Neuchâtelois",
    "description": "Complete API collection for the RHNe hospital network platform.\n\n**Base URL:** `http://localhost:5000/api/v1`\n\n**Authentication:** Login first, the collection automatically stores tokens.\n\n**Languages:** Set `Accept-Language` header to `fr`, `en`, `de`, or `it`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "siteId", "value": "" },
    { "key": "siteSlug", "value": "pourtales" },
    { "key": "serviceId", "value": "" },
    { "key": "serviceSlug", "value": "" },
    { "key": "doctorId", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "eventSlug", "value": "" },
    { "key": "jobId", "value": "" },
    { "key": "newbornId", "value": "" },
    { "key": "patientInfoId", "value": "" },
    { "key": "patientInfoSlug", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "serviceContactId", "value": "" },
    { "key": "serviceLinkId", "value": "" },
    { "key": "resetToken", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
  },
  "item": [
    {
      "name": "Health & Info",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/health",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "API Info",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Super Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('accessToken', data.tokens.access_token);",
                  "  pm.collectionVariables.set('refreshToken', data.tokens.refresh_token);",
                  "  pm.test('Login successful', () => {",
                  "    pm.expect(data.user.email).to.equal('superadmin@rhne-clone.ch');",
                  "    pm.expect(data.user.roles).to.include('super_admin');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@rhne-clone.ch\",\n  \"password\": \"SuperAdmin123!\"\n}"
            }
          }
        },
