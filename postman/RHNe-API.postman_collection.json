    {
      "name": "Public — Sites",
      "item": [
        {
          "name": "List Sites",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.test('Returns sites array', () => {",
                  "    pm.expect(data.success).to.be.true;",
                  "    pm.expect(data.data).to.be.an('array');",
                  "  });",
                  "  if (data.data.length > 0) {",
                  "    pm.collectionVariables.set('siteSlug', data.data[0].slug);",
                  "    pm.collectionVariables.set('siteId', data.data[0]._id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/sites?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["sites"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "lang", "value": "fr", "disabled": true }
              ]
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Site by Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/sites/{{siteSlug}}",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
